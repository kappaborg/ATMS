<?xml version="1.0" encoding="UTF-8"?>
<!-- Demo scenario routes — 5-minute pilot-pitch demo.
     - Steady cross-traffic on both axes (visually alive without being chaotic).
     - One scripted emergency vehicle approaches from the east at sim-time 60s
       so the presenter can talk through the EV preempt path live.
     - A bus on the NS axis provides a transit-priority talking point.
     The detailed scripted events (preempt, ped call, fault injection) are
     fired by simulation/demo/__main__.py, NOT by these routes — vehicle
     entry timings here just provide the visual backdrop. -->
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

  <vType id="car"  accel="2.5" decel="4.5" length="5.0"  maxSpeed="13.89" sigma="0.5" color="0.5,0.5,0.9"/>
  <vType id="bus"  accel="1.5" decel="3.5" length="12.0" maxSpeed="13.89" sigma="0.3" color="1,0.6,0"/>
  <vType id="emerg" accel="3.0" decel="6.0" length="6.0" maxSpeed="22.22" sigma="0.0" color="1,0,0"
         vClass="emergency"/>

  <route id="r_ns" edges="ns_in ns_out"/>
  <route id="r_ew" edges="ew_in ew_out"/>

  <!-- Continuous flows for the demo backdrop. Higher density than rush-hour
       to keep the sumo-gui window visually busy at any moment. -->
  <flow id="flow_ns" type="car" route="r_ns" begin="0" end="300" vehsPerHour="900"/>
  <flow id="flow_ew" type="car" route="r_ew" begin="0" end="300" vehsPerHour="700"/>

  <!-- Transit bus on NS — talking point for transit-priority extension. -->
  <vehicle id="bus_ns_1" type="bus" route="r_ns" depart="30" departLane="0"/>
  <vehicle id="bus_ns_2" type="bus" route="r_ns" depart="180" departLane="0"/>

  <!-- Scripted emergency vehicle on EW. Enters at t=60s so the presenter can
       narrate the V2X BSM ingestion + preempt-arm path while it approaches. -->
  <vehicle id="ev_east_1" type="emerg" route="r_ew" depart="60" departLane="0" departSpeed="max"/>

</routes>
