{
  "models": {
    "license_plate": "models/license_plate_model_mps/best.pt",
    "top_view": "models/top_view_vehicle_model.pt",
    "front_bumper": "models/front_bumper_model.pt",
    "side_profile": "models/side_profile_vehicle_model.pt"
  },
  "detection": {
    "confidence_threshold": 0.5,
    "iou_threshold": 0.45,
    "max_detections": 100
  },
  "tracking": {
    "max_disappeared": 30,
    "max_distance": 50,
    "tracking_threshold": 0.3
  },
  "fusion": {
    "weights": {
      "license_plate": 0.4,
      "top_view": 0.3,
      "front_bumper": 0.2,
      "side_profile": 0.1
    },
    "min_confidence": 0.3,
    "max_detections_per_view": 10
  },
  "trajectory": {
    "max_history": 100,
    "prediction_frames": 5,
    "speed_calculation": true,
    "direction_analysis": true
  }
}
