{
  "title": "Traffic Management System - Real-Time Dashboard",
    "tags": ["traffic", "monitoring", "real-time"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "FPS - Current",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "traffic_fps_current",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "fps",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 10, "color": "yellow"},
                {"value": 15, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "FPS - Average",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "traffic_fps_average",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "fps",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 10, "color": "yellow"},
                {"value": 15, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Vehicles Detected",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "traffic_vehicles_detected",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        }
      },
      {
        "id": 4,
        "title": "Pedestrians Detected",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "traffic_pedestrians_detected",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        }
      },
      {
        "id": 5,
        "title": "Frame Processing Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(traffic_frame_processing_time_ms_bucket[1m]))",
            "legendFormat": "95th percentile",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(traffic_frame_processing_time_ms_bucket[1m]))",
            "legendFormat": "50th percentile",
            "refId": "B"
          },
          {
            "expr": "rate(traffic_frame_processing_time_ms_sum[1m]) / rate(traffic_frame_processing_time_ms_count[1m])",
            "legendFormat": "Average",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "decimals": 1
          }
        }
      },
      {
        "id": 6,
        "title": "Detection Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(traffic_detection_time_ms_bucket[1m]))",
            "legendFormat": "95th percentile",
            "refId": "A"
          },
          {
            "expr": "rate(traffic_detection_time_ms_sum[1m]) / rate(traffic_detection_time_ms_count[1m])",
            "legendFormat": "Average",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "decimals": 1
          }
        }
      },
      {
        "id": 7,
        "title": "Total Detections",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "rate(traffic_detections_total[1m])",
            "legendFormat": "Detections/sec",
            "refId": "A"
          },
          {
            "expr": "rate(traffic_detections_filtered[1m])",
            "legendFormat": "Filtered/sec",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "decimals": 1
          }
        }
      },
      {
        "id": 8,
        "title": "System Resources",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "traffic_memory_usage_mb",
            "legendFormat": "Memory (MB)",
            "refId": "A"
          },
          {
            "expr": "traffic_cpu_usage_percent",
            "legendFormat": "CPU (%)",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 1
          }
        }
      },
      {
        "id": 9,
        "title": "Decision Confidence",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(traffic_decision_confidence_bucket[1m]))",
            "legendFormat": "Median Confidence",
            "refId": "A"
          },
          {
            "expr": "rate(traffic_decisions_total[1m])",
            "legendFormat": "Decisions/sec",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 2
          }
        }
      },
      {
        "id": 10,
        "title": "Traffic Metrics",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "traffic_vehicle_count_north_south",
            "legendFormat": "NS Vehicles",
            "refId": "A"
          },
          {
            "expr": "traffic_vehicle_count_east_west",
            "legendFormat": "EW Vehicles",
            "refId": "B"
          },
          {
            "expr": "traffic_emission_north_south_kg",
            "legendFormat": "NS Emission (kg)",
            "refId": "C"
          },
          {
            "expr": "traffic_emission_east_west_kg",
            "legendFormat": "EW Emission (kg)",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 1
          }
        }
      }
    ],
    "time": {
      "from": "now-15m",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "id": null,
    "uid": "traffic-system",
    "version": 1
}

