{
  "_comment": "ATMS local-dev realm export. Generated for the OIDC integration runbook (docs/runbooks/oidc-keycloak.md). DEV ONLY — see docker-compose.keycloak.yml header. The audience mapper on each client puts the client_id into the JWT 'aud' claim so services can validate AUTH_AUDIENCE without extra configuration.",
  "realm": "atms",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 3600,
  "offlineSessionIdleTimeout": 2592000,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      {
        "name": "viewer",
        "description": "ATMS viewer — read-only dashboards and status endpoints"
      },
      {
        "name": "operator",
        "description": "ATMS operator — manual phase override, preempt, ped-call"
      },
      {
        "name": "engineer",
        "description": "ATMS engineer — DSAR, mode change, V2X injection, model promotion"
      },
      {
        "name": "admin",
        "description": "ATMS admin — all of the above plus mode/auto, IdP rotation"
      }
    ]
  },
  "defaultRoles": ["viewer"],
  "clientScopes": [
    {
      "name": "atms-audience",
      "description": "ATMS service audience scope — wraps the client-audience mapper.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "atms-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "atms-traffic-controller",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-traffic-controller-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": ["roles", "atms-audience", "profile", "email"],
      "protocolMappers": [
        {
          "name": "audience-traffic-controller",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "atms-traffic-controller",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "atms-decision-engine",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-decision-engine-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": ["roles", "atms-audience", "profile", "email"],
      "protocolMappers": [
        {
          "name": "audience-decision-engine",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "atms-decision-engine",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "atms-v2x-interface",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-v2x-interface-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": ["roles", "atms-audience", "profile", "email"],
      "protocolMappers": [
        {
          "name": "audience-v2x-interface",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "atms-v2x-interface",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "atms-api-gateway",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-api-gateway-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": ["roles", "atms-audience", "profile", "email"],
      "protocolMappers": [
        {
          "name": "audience-api-gateway",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "atms-api-gateway",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "dev-viewer",
      "enabled": true,
      "emailVerified": true,
      "email": "dev-viewer@atms.local",
      "firstName": "Dev",
      "lastName": "Viewer",
      "credentials": [
        {
          "type": "password",
          "value": "dev-viewer-password",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    },
    {
      "username": "dev-operator",
      "enabled": true,
      "emailVerified": true,
      "email": "dev-operator@atms.local",
      "firstName": "Dev",
      "lastName": "Operator",
      "credentials": [
        {
          "type": "password",
          "value": "dev-operator-password",
          "temporary": false
        }
      ],
      "realmRoles": ["operator", "viewer"]
    },
    {
      "username": "dev-engineer",
      "enabled": true,
      "emailVerified": true,
      "email": "dev-engineer@atms.local",
      "firstName": "Dev",
      "lastName": "Engineer",
      "credentials": [
        {
          "type": "password",
          "value": "dev-engineer-password",
          "temporary": false
        }
      ],
      "realmRoles": ["engineer", "operator", "viewer"]
    },
    {
      "username": "dev-admin",
      "enabled": true,
      "emailVerified": true,
      "email": "dev-admin@atms.local",
      "firstName": "Dev",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "dev-admin-password",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "engineer", "operator", "viewer"]
    }
  ]
}
