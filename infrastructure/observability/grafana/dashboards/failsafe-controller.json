{
  "title": "ATMS — Failsafe Controller",
  "description": "Per-intersection failsafe state machine: mode, AI decision age, transitions, preempt/ped events. Source: structured logs in Loki + Prometheus metrics from the controller. Trace_id click-through to Tempo.",
  "tags": ["atms", "phase-a1", "phase-a7", "phase-b3"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "intersection_id",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({service=\"traffic-controller\"}, intersection_id)",
        "current": {"text": "1", "value": "1"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Current mode",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "atms_controller_mode{intersection_id=\"$intersection_id\"} == 1",
          "legendFormat": "{{mode}}"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "AI decision age (ms)",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "atms_controller_ai_decision_age_ms{intersection_id=\"$intersection_id\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1500},
              {"color": "red", "value": 2000}
            ]
          }
        }
      },
      "gridPos": {"x": 6, "y": 0, "w": 18, "h": 8}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Mode transitions per minute",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(atms_controller_mode_transitions_total{intersection_id=\"$intersection_id\"}[5m])",
          "legendFormat": "{{from}} → {{to}} ({{reason}})"
        }
      ],
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "EV preempts armed / cleared",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(atms_controller_preempt_armed_total{intersection_id=\"$intersection_id\"}[5m])",
          "legendFormat": "armed ({{priority}})"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(atms_controller_preempt_cleared_total{intersection_id=\"$intersection_id\"}[5m])",
          "legendFormat": "cleared ({{reason}})"
        }
      ],
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Mode transition events (with trace_id)",
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{service=\"traffic-controller\", intersection_id=\"$intersection_id\"} |= \"controller_mode_transition\" | json"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true
      },
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 10}
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Operator actions (audit trail)",
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{service=\"traffic-controller\"} |= \"operator_action\" | json"
        }
      ],
      "gridPos": {"x": 0, "y": 26, "w": 24, "h": 8}
    }
  ]
}
