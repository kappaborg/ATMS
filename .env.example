# ATMS environment template
# Copy to `.env` for local dev. NEVER commit `.env`.
# Production secrets live in SOPS-encrypted files under `deploy/secrets/`
# (see docs/adr/0002-secrets-management-sops-age.md).

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=atms
POSTGRES_USER=atms
POSTGRES_PASSWORD=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- pgAdmin (dev UI) ---
PGADMIN_PASSWORD=

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Run mode ---
# See atms_config.py: deployment | experiment
ATMS_RUN_MODE=deployment
ATMS_ENABLE_KAFKA=true

# --- Failsafe controller (Phase A1) ---
# Maximum age of the latest AI decision before controller falls back to fixed-time.
ATMS_MAX_AI_STALENESS_MS=2000
# Window (seconds) used for flap detection.
ATMS_FAILSAFE_FLAP_WINDOW_S=300
# Number of AI_ADAPTIVE -> FIXED_TIME transitions within the window that trigger ALL_RED_FLASH.
ATMS_FAILSAFE_FLAP_THRESHOLD=3
# Path (in-container) to the fixed-time plan YAML used when AI is unhealthy.
ATMS_FIXED_TIME_PLAN_PATH=/etc/atms/fixed_time_plan.yaml

# --- Authentication (Phase A6 — see docs/adr/0006-rbac-jwt-roles.md) ---
# Algorithm: HS256 (dev/test) or RS256 (production via OIDC JWKS).
AUTH_ALGORITHM=HS256
AUTH_ISSUER=atms-dev
AUTH_AUDIENCE=atms-traffic-controller
# HS256 path: shared secret. >= 32 bytes recommended. Production: load from SOPS.
AUTH_HS256_SECRET=
# RS256 path: JWKS endpoint of the OIDC IdP (Keycloak, etc.). Stub until A6-RS.
AUTH_JWKS_URI=
# Allowed clock skew in seconds between the token issuer and this service.
AUTH_CLOCK_SKEW_S=30

# --- Privacy (ADR-0014) ---
# Deployment-specific HMAC salt for plate anonymization (>= 32 chars).
# Same plate + same salt => same subject_id; without it, ai-perception
# uses an ephemeral salt and subject_ids are not stable across restarts.
# Generate: `openssl rand -hex 32`. Production: load from SOPS.
ATMS_PLATE_SALT=

# --- API gateway ---
# API keys are never hardcoded. Format: <key>:<name>:<rate_limit>, comma-separated.
# Generate keys with e.g. `openssl rand -hex 32`. Production: load from SOPS.
ATMS_API_KEYS=

# --- Observability (Phase B) ---
# B2 — OpenTelemetry tracing (ADR-0010)
# In dev (no collector running) leave ATMS_OTEL_DEV=1: spans go to stdout.
# In staging / prod set it to 0 and point at the cluster collector.
ATMS_OTEL_DEV=1
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# 1.0 = 100% sampling (dev). 0.01 = 1% (prod). Parent-based sampler honours
# upstream decisions for child spans regardless of this root rate.
OTEL_TRACES_SAMPLER_ARG=1.0
# B3 — structured logging
LOG_LEVEL=INFO
# B1 — service identity (also propagated into logs/traces)
ATMS_INTERSECTION_ID=1

# Predictive congestion in the decision engine (on by default).
ATMS_USE_PREDICTIONS=1

# Panel multi-operator RBAC (user:role:password; role=viewer|operator|admin)
PANEL_USERS=
PANEL_AUTH_SECRET=
